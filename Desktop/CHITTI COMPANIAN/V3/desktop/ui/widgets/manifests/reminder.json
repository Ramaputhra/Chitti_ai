{
  "manifest_version": "1.0.0",
  "widget_version": "1.0.0",
  "widget_id": "widget_reminder",
  "display_name": "Reminder Widget",
  "category": "PRODUCTIVITY",
  "version": "1.0.0",
  "description": "Canonical CHITTI Reminder Widget",
  "supported_runtime_sessions": ["Reminder"],
